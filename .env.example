# Telegram
TELEGRAM_BOT_TOKEN=          # מ-BotFather (ראה מדריך)
TELEGRAM_CHAT_ID=            # ה-chat ID שלך בטלגרם (ראה מדריך)

# Meta API
META_PAGE_ACCESS_TOKEN=      # Long-lived Page Access Token (אותו token מ-bot הישן)
INSTAGRAM_ACCOUNT_ID=        # Instagram Business Account ID
FACEBOOK_PAGE_ID=            # Facebook Page ID

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# אופציונלי
DB_PATH=messages.db
SCAN_HOURS=12                # כל כמה שעות לסרוק (ברירת מחדל: 12)
